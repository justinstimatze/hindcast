# Copy to .env. .env is gitignored. Only required for `hindcast eval-api`.

# Anthropic API key — used by `hindcast eval-api` to A/B stock vs hindcast-
# injected estimates. Hooks and the predictor never make network calls;
# this key is only read when you run the eval-api command directly.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Predictor knobs (all optional — defaults are sensible):

# Suppress hook output to Claude (predictor still records turns).
# HINDCAST_INJECT=0

# Re-enable v0.1 ungated full-bucket-table injection. Useful only for A/B
# research against the v0.6.x gated band.
# HINDCAST_LEGACY_INJECT=1

# kNN recency weighting half-life in days. 60 by default; ≤0 disables.
# HINDCAST_FRESHNESS_HALFLIFE_DAYS=60

# Skip recording for this session entirely.
# HINDCAST_SKIP=1

# Percentage of sessions in the A/B control arm (0-100, default 10).
# Only relevant when HINDCAST_LEGACY_INJECT is enabled.
# HINDCAST_CONTROL_PCT=10
